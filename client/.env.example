VITE_API_URL=/api

# Session check tuning (milliseconds)
# Initial check delay after login/app mount
VITE_SESSION_INITIAL_DELAY_MS=1500
# Poll interval while examinee is on exam screen
VITE_SESSION_POLL_EXAM_MS=30000
# Poll interval while examinee is outside exam screen
VITE_SESSION_POLL_IDLE_MS=90000
# Extra delay added per failure (backoff)
VITE_SESSION_BACKOFF_STEP_MS=10000
# Max cumulative backoff
VITE_SESSION_BACKOFF_MAX_MS=60000
# Consecutive failures before forced logout
VITE_SESSION_MAX_FAILURES=2
